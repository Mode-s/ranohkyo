---
import { Image } from 'astro:assets';
import { content } from '../../config/content';

const { title, items } = content.menu;
---
<section class="section rooms" id="rooms">
  <div class="inner rooms-inner">
    <header class="section-title">
      <h2 class="title">{title}</h2>
    </header>

    <ul class="room-list">
      {items.map((item) => (
        <li class="room-card">
          <div class="room-img-wrap">
            <Image class="room-img" src={item.image} alt={item.name} />
          </div>
          <div class="room-body">
            <h3 class="room-name">{item.name}</h3>
            {item.price && <p class="room-price">{item.price}</p>}
            {item.description && <p class="room-desc">{item.description}</p>}
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>

<style lang="scss">
  @use "../../styles/variables" as *;
  @use "../../styles/mixins" as *;

  .section-title {
    margin-bottom: 40px;
    text-align: center;
  }

  .title {
    font-size: $fs-2xl;
  }

  .room-list {
    display: grid;
    gap: 48px;
    max-width: 720px;
    margin: 0 auto;
  }

  .room-card {
    display: grid;
    gap: 20px;
  }

  .room-img-wrap {
    overflow: hidden;
  }

  .room-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: 16 / 9;
  }

  .room-body {
    display: grid;
    gap: 8px;
    text-align: center;
  }

  .room-name {
    font-size: $fs-lg;
  }

  .room-price {
    font-size: $fs-xl;
    color: $accent-c;
  }

  .room-desc {
    font-size: $fs-sm;
    color: $sub-c;
  }

  @include sp {
    .section-title {
      margin-bottom: 28px;
    }

    .room-list {
      gap: 36px;
    }
  }
</style>