---
import { Image } from 'astro:assets';
import { content } from '../../config/content';

const { title, items } = content.menu;
---
<section class="section rooms" id="rooms">
  <div class="inner rooms-inner">
    <header class="section-title" data-reveal>
      <h2 class="title">{title}</h2>
    </header>

    <ul class="room-list">
      {items.map((item, i) => (
        <li class="room-card" data-reveal style={`--reveal-delay:${i * 0.1}s`}>
          <div class="room-img-wrap">
            {item.images.length > 1 ? (
              <div class="room-slider" data-room-slider>
                {item.images.map((src, j) => (
                  <Image
                    class:list={['room-img', 'room-slide', { 'is-active': j === 0 }]}
                    src={src}
                    alt={item.name}
                    data-slide={j}
                  />
                ))}
                <div class="room-indicators">
                  {item.images.map((_, j) => (
                    <button
                      type="button"
                      class:list={['room-indicator', { 'is-active': j === 0 }]}
                      aria-label={`${j + 1}枚目`}
                      data-index={j}
                    />
                  ))}
                </div>
              </div>
            ) : (
              <Image class="room-img" src={item.images[0]} alt={item.name} />
            )}
          </div>
          <div class="room-body">
            <h3 class="room-name">{item.name}</h3>
            {item.price && <p class="room-price">{item.price}</p>}
            {item.description && <p class="room-desc">{item.description}</p>}
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>

<style lang="scss">
  @use "../../styles/variables" as *;
  @use "../../styles/mixins" as *;

  .section-title {
    margin-bottom: 40px;
    text-align: center;
  }

  .title {
    font-size: $fs-2xl;
  }

  .room-list {
    display: grid;
    gap: 48px;
    max-width: 720px;
    margin: 0 auto;
  }

  .room-card {
    display: grid;
    gap: 20px;
  }

  .room-img-wrap {
    overflow: hidden;
  }

  .room-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: 16 / 9;
  }

  .room-slider {
    position: relative;
    aspect-ratio: 16 / 9;
  }

  .room-slide {
    position: absolute;
    inset: 0;
    aspect-ratio: auto;
    opacity: 0;
    transition: opacity 1.2s ease;
    pointer-events: none;

    &.is-active {
      opacity: 1;
    }
  }

  .room-indicators {
    position: absolute;
    display: flex;
    bottom: 12px;
    left: 50%;
    transform: translateX(-50%);
    gap: 8px;
    z-index: 1;
  }

  .room-indicator {
    width: 8px;
    height: 8px;
    padding: 0;
    border: none;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.5);
    cursor: pointer;

    &.is-active {
      background: #fff;
    }
  }

  .room-body {
    display: grid;
    gap: 8px;
    text-align: center;
  }

  .room-name {
    font-size: $fs-lg;
  }

  .room-price {
    font-size: $fs-xl;
    color: $accent-c;
  }

  .room-desc {
    font-size: $fs-sm;
    color: $sub-c;
  }

  @include sp {
    .section-title {
      margin-bottom: 28px;
    }

    .room-list {
      gap: 36px;
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-room-slider]').forEach((slider) => {
    const slides = slider.querySelectorAll<HTMLElement>('.room-slide');
    const indicators = slider.querySelectorAll<HTMLButtonElement>('.room-indicator');
    if (slides.length <= 1) return;

    let current = 0;
    let timer: ReturnType<typeof setInterval>;

    const goTo = (index: number) => {
      slides[current]?.classList.remove('is-active');
      indicators[current]?.classList.remove('is-active');
      current = index;
      slides[current]?.classList.add('is-active');
      indicators[current]?.classList.add('is-active');
    };

    const start = () => {
      timer = setInterval(() => goTo((current + 1) % slides.length), 5000);
    };

    indicators.forEach((btn, i) => {
      btn.addEventListener('click', () => {
        clearInterval(timer);
        goTo(i);
        start();
      });
    });

    start();
  });
</script>
