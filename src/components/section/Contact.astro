---
import { Icon } from 'astro-icon/components';
import { siteConfig } from '../../config/site';

const { shop, sns } = siteConfig;

const snsLinks = [
  { label: "Booking.com",         href: sns.booking,         icon: "simple-icons:bookingdotcom" },
  { label: "airbnb",              href: sns.airbnb,          icon: "simple-icons:airbnb" },
  { label: "trivago",             href: sns.trivago,         icon: "simple-icons:trivago" },
].filter(( item ) => item.href );
---
<section class="section contact" id="contact">
  <div class="inner contact-inner">
    <header class="section-title">
      <h2 class="title">お問い合わせ</h2>
    </header>
    <div class="contact-body">
      {shop.tel.display && (
        <a class="contact-tel" href={`tel:${shop.tel.link}`}>
          <Icon class="contact-tel-icon" name="mdi:phone" />
          <span class="contact-tel-text">{shop.tel.display}</span>
        </a>
      )}
      {snsLinks.length > 0 && (
        <ul class="contact-sns-list">
          {snsLinks.map((item) => (
            <li class="contact-sns-item">
              <a
                class="contact-sns-link"
                href={item.href}
                target="_blank"
                rel="noopener noreferrer"
              >
                <Icon class="contact-sns-icon" name={item.icon} />
                <span class="contact-sns-text">{item.label}</span>
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </div>
</section>
<style lang="scss">
  @use "../../styles/variables" as *;
  @use "../../styles/mixins" as *;
  .contact-inner {
    
  }
  .section-title {
    margin-bottom: 40px;
  }

  .contact-body {
    display: flex;
    justify-content: center;
    max-width: 700px;
    gap: 32px;
    margin: 0 auto;
  }

  .contact-tel {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    max-width: 300px;
    width: 100%;
    padding: 16px 24px;
    border: 1px solid $accent-c;
    color: $main-c;
    font-size: $fs-lg;
    transition: opacity 0.3s ease;
    &:hover {
      opacity: 0.7;
    }
  }

  .contact-tel-icon {
    width: 24px;
    height: 24px;
  }

  .contact-sns-list {
    display: grid;
    gap: 12px;
  }

  .contact-sns-item {
    max-width: 200px;
    width: 100%;
    margin: 0 auto;
  }

  .contact-sns-link {
    display: flex;
    align-items: center;
    max-width: 200px;
    gap: 12px;
    padding: 14px 20px;
    background: $muted-c;
    color: $main-c;
    transition: opacity 0.3s ease;
    &:hover {
      opacity: 0.7;
    }
  }

  .contact-sns-icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  @include sp {
    .section-title {
      margin-bottom: 28px;
    }

    .contact-body {
      flex-direction: column;
      gap: 24px;
    }

    .contact-tel {
      max-width: 200px;
      width: 100%;
      margin: 0 auto;
    }
  }
</style>