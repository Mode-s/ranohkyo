---
import { Icon } from 'astro-icon/components';
import { content } from '../../config/content';

const { rooms, amenities } = content.price;
---
<section class="section price" id="price">
  <div class="inner price-inner">
    <header class="section-title" data-reveal>
      <h2 class="title">料金</h2>
    </header>

    <section class="price-block">
      <h3 class="price-heading" data-reveal>ルーム</h3>
      <p class="price-label" data-reveal style="--reveal-delay:0.08s">宿泊料金について</p>
      <p class="label-description" data-reveal style="--reveal-delay:0.16s">当施設では、曜日・季節・イベント開催状況・予約状況に応じて、宿泊料金が変動する「ダイナミックプライシング（変動料金制）」を採用しております。</p>
      <ul class="room-list">
        {rooms.map((room, i) => (
          <li class="room-item" data-reveal style={`--reveal-delay:${i * 0.08}s`}>
            <div class="room-head">
              <h5 class="room-name">{room.name}</h5>
              <p class="room-price">¥{room.price.toLocaleString()}～</p>
            </div>
            <p class="room-bed">ベッドタイプ：{room.bedType}</p>
            <p class="room-bed">{room.description}</p>
          </li>
        ))}
      </ul>
    </section>

    <section class="price-block">
      <h3 class="price-heading" data-reveal>設備</h3>
      <ul class="amenity-list">
        {amenities.map((item, i) => (
          <li class="amenity-item" data-reveal style={`--reveal-delay:${i * 0.06}s`}>
            <Icon class="amenity-icon" name={item.icon} />
            <span class="amenity-label">{item.label}</span>
          </li>
        ))}
      </ul>
    </section>
  </div>
</section>

<style lang="scss">
  @use "../../styles/variables" as *;
  @use "../../styles/mixins" as *;

  .section-title {
    margin-bottom: 40px;
    text-align: center;
  }

  .title {
    font-size: $fs-2xl;
  }

  .price-block + .price-block {
    margin-top: 48px;
  }

  .price-heading {
    margin-bottom: 20px;
    padding-bottom: 8px;
    border-bottom: 1px solid $muted-c;
    font-size: $fs-lg;
    color: $sub-c;
  }

  .room-list {
    display: grid;
    gap: 16px;
    margin-top: 30px;
  }

  .room-item {
    padding: 20px 24px;
    background: $muted-c;
  }

  .room-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 8px;
  }

  .room-name {
    font-size: $fs-lg;
  }

  .room-price {
    font-size: $fs-xl;
    color: $accent-c;
    white-space: nowrap;
  }

  .room-bed {
    font-size: $fs-sm;
    color: $sub-c;
  }

  .amenity-list {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .amenity-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 20px 12px;
    background: $muted-c;
    text-align: center;
  }

  .amenity-icon {
    width: 28px;
    height: 28px;
    color: $accent-c;
  }

  .amenity-label {
    font-size: $fs-sm;
    line-height: 1.5;
  }

  @include tb {
    .amenity-list {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @include sp {
    .section-title {
      margin-bottom: 28px;
    }

    .price-block + .price-block {
      margin-top: 36px;
    }

    .room-head {
      flex-direction: column;
      gap: 4px;
    }

    .amenity-list {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>