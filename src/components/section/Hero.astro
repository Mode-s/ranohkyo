---
import { Image } from 'astro:assets';

import hero from '../../assets/images/hero04.png';
import hero2 from '../../assets/images/hero.png';
import hero3 from '../../assets/images/hero03.png';
import hero4 from '../../assets/images/hero05.png';
import hero5 from '../../assets/images/hero06.png';
import hero6 from '../../assets/images/hero07.png';
import hero7 from '../../assets/images/hero08.png';


const slides = [hero, hero2, hero3, hero4, hero5, hero6, hero7];

---
<section class="hero">
  <div class="slider" data-reveal data-reveal-load>
    {
      slides.map((src, i) => (
        <Image
          class:list={['hero-img', { 'is-active': i === 0 }]}
          src={src}
          alt=""
          data-slide={i}
        />
      ))
    }
  </div>
  <div class="indicators" data-reveal data-reveal-load style="--reveal-delay: 0.3s">
    {
      slides.map((_, i) => (
        <button
          type="button"
          class:list={['indicator', { 'is-active': i === 0 }]}
          aria-label={`${i + 1}枚目`}
          data-index={i}
        />
      ))
    }
  </div>
</section>

<style lang="scss">
  @use "../../styles/variables" as *;
  @use "../../styles/mixins" as *;


  // ――――――――――――――――――――――――――――――――――― hero
  .hero {
    position: relative;
  }
  // ――――――――――――――――――――――――――――――――――― hero-picture
  .slider {
    position: relative;
    height: 100svh;

    &::after {
      content: "";
      position: absolute;
      inset: 0;
      background: rgba(0, 0, 0, 0.35);
      pointer-events: none;
      z-index: 1;
    }
  }

  .hero-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    object-fit: cover;
    transition: opacity 1.2s ease;
    pointer-events: none;

    &.is-active {
      opacity: 0;
    }
  }

  :global(.js-reveal.is-ready) .hero-img.is-active {
    opacity: 1;
  }

  .indicators {
    position: absolute;
    display: flex;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    gap: 12px;
    z-index: 1;
  }

  .indicator {
    width: 10px;
    height: 10px;
    padding: 0;
    border: none;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.5);
    cursor: pointer;
    &.is-active {
      background: #fff;
    }
  }

  //―――――――――――――――――――――――――――――――――――――― ブレークポイント / タブレット
  @include tb {

  }

  //―――――――――――――――――――――――――――――――――――――― ブレークポイント / スマホ
  @include sp {

  }
</style>

<script>
  const hero = document.querySelector('.hero');
  if (!hero) throw new Error();
  const slides = hero.querySelectorAll<HTMLElement>('.hero-img');
  const indicators = hero.querySelectorAll<HTMLButtonElement>('.indicator');
  let current = 0;
  let timer: ReturnType<typeof setInterval>;
  const goTo = (index: number) => {
    slides[current]?.classList.remove('is-active');
    indicators[current]?.classList.remove('is-active');
    current = index;
    slides[current]?.classList.add('is-active');
    indicators[current]?.classList.add('is-active');
  };
  const start = () => {
    timer = setInterval(() => goTo((current + 1) % slides.length), 5000);
  };
  indicators.forEach((btn, i) => {
    btn.addEventListener('click', () => {
      clearInterval(timer);
      goTo(i);
      start();
    });
  });
  start();
</script>