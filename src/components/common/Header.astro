---
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import { content } from '../../config/content';

const { logo, nav } = content.header;
---
<header class="header">
  <div class="inner header-inner">
    <h1 class="header-logo" data-reveal data-reveal-load>
      <a class="logo-link" href={logo.href}>
        <Image class="logo-img" src={logo.src} alt={logo.alt}  />
      </a>
    </h1>
    <button class="hamburger" type="button" aria-label="メニュー" aria-expanded="false" aria-controls="nav-menu" data-reveal data-reveal-load style="--reveal-delay: 0.15s">
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>
    <nav class="nav">
      <ul class="nav-list" data-reveal data-reveal-load style="--reveal-delay: 0.15s">
        {nav.map((item) => (
          <li class="nav-item">
            <a class="nav-link" href={item.href}>
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style lang="scss">
  @use "../../styles/variables" as *;
  @use "../../styles/mixins" as *;

  // ―――――――――――――――――――――――――――――――――――
  .header {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    color: $base-c;
    z-index: 100;
  }
  // ―――――――――――――――――――――――――――――――――――
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1200px;
    width: 90%;
    padding: 15px;
  }

  .header-logo {
    position: relative;
    max-width: 100px;
    z-index: 120;
  }

  .logo-link {

  }

  .logo-img {
    filter: brightness(0) invert(1);
  }

  .nav-list {
    display: flex;
    gap: 40px;
  }

  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: space-between;
    width: 32px;
    height: 32px;
    padding: 5px;
    z-index: 120;
    overflow: visible;

    .hamburger-line {
      display: block;
      width: 100%;
      height: 2px;
      background: currentColor;
      transition: transform 0.3s ease, opacity 0.3s ease;
    }
  }
  //―――――――――――――――――――――――――――――――――――――― タブレット
  @include tb {
    .hamburger {
      display: flex;
    }
    // メニュー本体：画面全体にふわっと表示
    .nav {
      position: fixed;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(0, 0, 0, 0.9);
      opacity: 0;
      visibility: hidden;
      transition: none;
      z-index: 110;
    }
    .nav-list {
      flex-direction: column;
      align-items: center;
      gap: 32px;
      color: #fff;
    }
    // 開いた状態
    .header.is-open .nav {
      opacity: 1;
      visibility: visible;
      transition: opacity 0.4s ease, visibility 0.4s ease;
    }
    .header.is-open .hamburger span:nth-child(1) {
      transform: translateY(10px) rotate(45deg);
    }
    .header.is-open .hamburger span:nth-child(2) {
      opacity: 0;
    }
    .header.is-open .hamburger span:nth-child(3) {
      transform: translateY(-10px) rotate(-45deg);
    }
  }
</style>

<script>
  const header = document.querySelector('.header');
  const btn = header?.querySelector('.hamburger');
  const links = header?.querySelectorAll('.nav-link');
  btn?.addEventListener('click', () => {
    const open = header!.classList.toggle('is-open');
    btn.setAttribute('aria-expanded', String(open));
  });
  links?.forEach((a) => a.addEventListener('click', () => {
    header!.classList.remove('is-open');
    btn?.setAttribute('aria-expanded', 'false');
  }));
</script>